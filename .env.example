# --- OKX config ---
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHASE=
OKX_INST_ID=ETH-USDT-SWAP
OKX_BAR=15m
OKX_TD_MODE=isolated
OKX_POS_SIDE_MODE=net
OKX_BASE_URL=https://www.okx.com

# --- live trading safety ---
LIVE_TRADING=false
MAX_LIVE_EQUITY_USDT=30

# --- email, failure only in live runner ---
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# --- BOLL params ---
BOLL_WINDOW=20
BOLL_STD_MULTIPLIER=2.0
BOLL_DISTANCE_THRESHOLD_PCT=0.005
BOLL_USE_LIVE_CANDLE=true
BOLL_RECALC_SECONDS=1

# --- candle polling / REST calibration ---
CANDLE_POLL_SECONDS=30
CANDLE_LIMIT=100

# --- original BOLL alert deduplication ---
# This is for the legacy BOLL breakout alert, not the live strategy order cooldown.
ALERT_FREEZE_SECONDS=3600

# --- fast CVD reclaim strategy ---
CVD_FAST_WINDOW_SECONDS=5
CVD_MIN_BUY_RATIO=0.55
CVD_MIN_SELL_RATIO=0.55
PRICE_STALL_SECONDS=2
PRICE_STALL_TOLERANCE_PCT=0.0005

# --- burst filter: block slow grinding moves along BOLL bands ---
# The burst filter is relative: short-window range/volume must expand vs baseline.
BURST_WINDOW_SECONDS=3
BURST_BASELINE_SECONDS=60
BURST_MIN_MOVE_RATIO=2.5
BURST_MIN_VOLUME_RATIO=2.0

# --- live/dry-run position sizing ---
# Live runner uses real OKX account equity; DRY_RUN_EQUITY_USDT is mainly for dry-run scripts.
DRY_RUN_EQUITY_USDT=1000
LAYER_MARGIN_PCT=0.03
LEVERAGE=50
ADD_LAYER_GAP_PCT=0.003
MAX_LAYERS=3
ORDER_COOLDOWN_SECONDS=10
TP_UPDATE_INTERVAL_SECONDS=900
MAX_ENTRY_DISTANCE_FROM_EXTREME_PCT=0.002
MAX_ARMED_SECONDS=900
BREAKEVEN_FEE_BUFFER_PCT=0.001

# --- account / position sync ---
POSITION_SYNC_SECONDS=5
ACCOUNT_SYNC_SECONDS=60
ACCOUNT_LOG_MIN_DELTA_USDT=0.01

# --- watchdog launcher ---
WATCHDOG_RESTART_SECONDS=5
WATCHDOG_MAX_RESTARTS=0
# Optional override if python command is not simply `python`.
# LIVE_PYTHON_BIN=/root/miniconda3/envs/c/bin/python
# LIVE_SCRIPT=scripts/run_boll_cvd_live.py
# LIVE_LOG_FILE=boll_cvd_live.out

# --- daily report / reserved configs ---
DAILY_REPORT_TIME=09:00
TARGET_NOTIONAL_USDT=1500000
