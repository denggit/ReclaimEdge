# ============================================================
# ReclaimEdge Unified Live Config Example
# ============================================================

EXCHANGE=okx
TRADE_ASSET=ETH
QUOTE_ASSET=USDT
MARKET_TYPE=PERPETUAL
MARGIN_MODE=isolated
POSITION_MODE=net
KLINE_INTERVAL=15m
LEVERAGE=20

# Unified API credential.
# When EXCHANGE=okx, fill OKX API here.
# Binance will use the same names in the future.
# Legacy OKX_API_* fallback exists only in the OKX adapter layer
# for backward compatibility; production config should use EXCHANGE_API_*.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# --- live trading safety ---
LIVE_TRADING=false
MAX_LIVE_EQUITY_USDT=30

# OKX adapter private REST infra.
# These are adapter infra settings, not trading symbol config.
OKX_PRIVATE_REST_TIMEOUT_SECONDS=10
OKX_PRIVATE_WRITE_RATE_LIMIT_ENABLED=true
OKX_PRIVATE_WRITE_MIN_INTERVAL_SECONDS=0.25

# --- email, failure only in live runner ---
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# --- BOLL params ---
BOLL_WINDOW=20
BOLL_STD_MULTIPLIER=2.0
BOLL_DISTANCE_THRESHOLD_PCT=0.005
BOLL_USE_LIVE_CANDLE=true
BOLL_RECALC_SECONDS=1

# TP-only BOLL window.
# BOLL_WINDOW remains the structure window for entry/add/risk/SL/runner.
# TP_BOLL_WINDOW is used only for SINGLE/MIDDLE/THREE-STAGE TP prices.
TP_BOLL_ENABLED=true
TP_BOLL_WINDOW=15

# --- candle polling / REST calibration ---
CANDLE_POLL_SECONDS=30
CANDLE_LIMIT=100

# --- original BOLL alert deduplication ---
# This is for the legacy BOLL breakout alert, not the live strategy order cooldown.
ALERT_FREEZE_SECONDS=3600

# --- fast CVD reclaim strategy ---
CVD_FAST_WINDOW_SECONDS=5
CVD_MIN_BUY_RATIO=0.55
CVD_MIN_SELL_RATIO=0.55
PRICE_STALL_SECONDS=2
PRICE_STALL_TOLERANCE_PCT=0.0005

# --- burst filter: block slow grinding moves along BOLL bands ---
# The burst filter is relative: short-window range/volume must expand vs baseline.
BURST_WINDOW_SECONDS=3
BURST_BASELINE_SECONDS=60
BURST_MIN_MOVE_RATIO=2.5
BURST_MIN_VOLUME_RATIO=2.0

# --- live/dry-run position sizing ---
# Live runner uses real OKX account equity; DRY_RUN_EQUITY_USDT is mainly for dry-run scripts.
DRY_RUN_EQUITY_USDT=1000
# LAYER_MARGIN_PCT is legacy fallback only and is not used for new risk-based entries.
# New entries use TRADE_RISK_PCT + ENTRY_MAX_STOP_DISTANCE_PCT + entry protective SL.
LEVERAGE=20
ORDER_COOLDOWN_SECONDS=10
TP_UPDATE_INTERVAL_SECONDS=900
MAX_ARMED_SECONDS=900
BREAKEVEN_FEE_BUFFER_PCT=0.001

# --- risk-first entry sizing ---
TRADE_RISK_PCT=0.003
ENTRY_FEE_SLIPPAGE_BUFFER_PCT=0.001
ENTRY_SL_BUFFER_PCT=0.0005
ENTRY_MIN_REWARD_RISK=1.0
ENTRY_RR_TARGET=STRUCTURE_MIDDLE

# --- CVD structure entry ---
ENTRY_CVD_STRUCTURE_MODE=DIVERGENCE_OR_ABSORPTION
ENTRY_CVD_DIVERGENCE_ENABLED=true
ENTRY_CVD_ABSORPTION_ENABLED=true
ENTRY_CVD_STRUCTURE_MIN_OUTSIDE_PCT=0.001

# --- reclaim soft confirm ---
ENTRY_RECLAIM_CONFIRM_SECONDS=1.0
ENTRY_RECLAIM_OUTSIDE_TOLERANCE_PCT=0.0002
ENTRY_RECLAIM_NEW_EXTREME_BUFFER_PCT=0.0001

# --- setup lifetime ---
ENTRY_MAX_EXTREME_TO_RECLAIM_SECONDS=900
ENTRY_MAX_TOTAL_SETUP_SECONDS=1800
ENTRY_MAX_RECLAIM_CYCLES=3

# --- post-entry SL cooldown ---
POST_ENTRY_SL_COOLDOWN_ENABLED=true
POST_ENTRY_SL_COOLDOWN_SECONDS=1800
# SIDE: after LONG entry SL, block only LONG; after SHORT entry SL, block only SHORT.
# GLOBAL remains supported but is more conservative.
POST_ENTRY_SL_COOLDOWN_SCOPE=SIDE

# --- Reclaim V2: event-anchored cumulative CVD divergence ---
# When true, the new Reclaim V2 path is used for entry gating.
# Old absorption / fast-CVD paths are logged but NOT allow entry.
ENTRY_RECLAIM_V2_ENABLED=true
ENTRY_RECLAIM_REQUIRE_ANCHORED_DIVERGENCE=true

# --- Reclaim V2 anchored CVD follow-through ---
# Minimum CVD recovery required at divergence extreme (anchored CVD improve vs previous extreme).
ENTRY_RECLAIM_MIN_CVD_RECOVERY=0
# Minimum CVD follow-through required after reclaim inside (anchored CVD vs divergence extreme).
ENTRY_RECLAIM_MIN_CVD_FOLLOW_THROUGH=0
# Maximum permitted inside-depth ratio for reclaim entry (0.15 = 15 % of band width from outer band).
# Prevents entries that chase too deep after reclaim — CVD must satisfy before this depth.
ENTRY_RECLAIM_MAX_INSIDE_DEPTH_RATIO=0.15

# --- Outside sweep volume profile / POC stop ---
ENTRY_SWEEP_PROFILE_ENABLED=true
ENTRY_SWEEP_PROFILE_BUCKET_PCT=0.0002
ENTRY_POC_STOP_ENABLED=true
# Use POC stop only when entry-to-extreme distance is at least this ratio.
# 0.008 = 0.8%.
ENTRY_POC_STOP_MIN_TAIL_PCT=0.008
ENTRY_POC_STOP_BUFFER_PCT=0.001
ENTRY_EXTREME_STOP_BUFFER_PCT=0.001

# --- entry protective stop-loss ---
# Maximum stop-distance distance ratio from entry price, used to cap the entry SL
# before position sizing. 0 = disabled (no hard ceiling).
# Risk-based sizing already reduces position size for wider stops.
ENTRY_MAX_STOP_DISTANCE_PCT=0
# Entry protective SL: retry count and interval for placement attempts.
ENTRY_PROTECTIVE_SL_RETRY_COUNT=3
ENTRY_PROTECTIVE_SL_RETRY_INTERVAL_SECONDS=1.0
# Entry SL placement failure must halt + notify for manual intervention; no automatic market exit.
ENTRY_SL_FAIL_MARKET_EXIT_RETRY_COUNT=3

# --- generic protective stop-loss (runner / three-stage / middle-bucket) ---
PROTECTIVE_SL_RETRY_COUNT=3
PROTECTIVE_SL_RETRY_INTERVAL_SECONDS=1
PROTECTIVE_SL_VERIFY_ATTEMPTS=3
PROTECTIVE_SL_VERIFY_INTERVAL_SECONDS=0.2

# --- trend breakout entry ---
# When enabled, the RegimeRouter decides between trend and mean-reversion entries.
TREND_BREAKOUT_ENABLED=false
# Trend middle trailing SL: tighten SL toward BOLL middle as trend progresses.
TREND_MIDDLE_TRAILING_SL_ENABLED=true
# Buffer away from BOLL middle for the trailing SL (fractional).
TREND_MIDDLE_SL_BUFFER_PCT=0.001
# Maximum allowed SL distance from entry as fraction of entry price.
TREND_MAX_STOP_DISTANCE_PCT=0.02
# Minimum interval between trailing SL updates (seconds).
TREND_SL_UPDATE_INTERVAL_SECONDS=900
# How long a compression episode remains valid after detection (seconds).
TREND_COMPRESSION_VALID_AFTER_SECONDS=7200
# Trend confirmation time window: minimum seconds before confirm.
TREND_CONFIRM_MIN_SECONDS=60
# Trend confirmation time window: max seconds before fail.
TREND_CONFIRM_MAX_SECONDS=180
# Minimum range expansion ratio for breakout.
TREND_RANGE_EXPANSION_RATIO_MIN=3.0
# Minimum volume expansion ratio for breakout.
TREND_VOLUME_EXPANSION_RATIO_MIN=3.0
# Minimum ratio of time spent outside BOLL band during confirm window.
TREND_OUTSIDE_OCCUPANCY_MIN_RATIO=0.70
# Minimum number of new extreme prices during breakout for confirm.
TREND_MIN_NEW_EXTREME_COUNT=2
# Max allowed time inside band before trend candidate fails (seconds).
TREND_MAX_INSIDE_RECLAIM_SECONDS=3
# CVD min buy ratio for UP trend confirmation.
TREND_CVD_MIN_BUY_RATIO=0.58
# CVD min sell ratio for DOWN trend confirmation.
TREND_CVD_MIN_SELL_RATIO=0.58
# Max allowed CVD pullback ratio from episode extreme.
TREND_CVD_MAX_PULLBACK_RATIO=0.45

# --- market exit runner ---
MARKET_EXIT_RUNNER_RETRY_COUNT=3
MARKET_EXIT_RUNNER_RETRY_INTERVAL_SECONDS=0.5

# --- Sidecar runtime has been removed ---
# Middle Runner, Three-Stage Runner and Trend Runner remain available for profit extension.

# --- take-profit management ---
# Three-Stage Trend Runner only applies when first TP mode is MIDDLE.
THREE_STAGE_RUNNER_ENABLED=true
THREE_STAGE_TP1_RATIO=0.60
THREE_STAGE_TP2_RATIO=0.20
THREE_STAGE_RUNNER_RATIO=0.20
# Three-Stage pre-TP1 stale degradation: 3h to Middle Runner, 6h to Single.
THREE_STAGE_PRE_TP1_DEGRADE_ENABLED=true
THREE_STAGE_PRE_TP1_MIDDLE_RUNNER_AFTER_SECONDS=10800
THREE_STAGE_PRE_TP1_SINGLE_AFTER_SECONDS=21600
# After TP1 middle is filled, protect the remaining 40% before TP2.
THREE_STAGE_POST_TP1_PROTECTIVE_SL_ENABLED=true
# Move post-TP1 protective SL to middle after price travels this ratio from middle to outer band.
THREE_STAGE_POST_TP1_SL_EXTENSION_TRIGGER_RATIO=0.60
RUNNER_DYNAMIC_ENABLED=true
# Reserved for future timer-based runner updates.
# Current Trend Runner TP/SL updates are driven by completed 15m BOLL candle timestamps.
RUNNER_DYNAMIC_UPDATE_SECONDS=900
RUNNER_TP_INITIAL_OUTER_EXTRA_PCT=0.010
RUNNER_TP_STEP_PCT=0.001
RUNNER_TP_MIN_OUTER_EXTRA_PCT=0.004
RUNNER_SL_INITIAL_OUTER_DISTANCE_RATIO=1.00
RUNNER_SL_STEP_RATIO=0.10
RUNNER_SL_MIN_OUTER_DISTANCE_RATIO=0.50
# Runner protective SL candle-count tightening.
# Applies only to Middle Runner and Three-Stage post-TP1 protective SL, not Sidecar fixed TP.
# Initial ratio is 0.50; each new 15m candle adds 0.05; 10 candles reaches the middle band.
RUNNER_PROTECTIVE_SL_TIME_TIGHTEN_ENABLED=true
RUNNER_PROTECTIVE_SL_TIME_TIGHTEN_STEP_RATIO=0.05
RUNNER_PROTECTIVE_SL_TIME_TIGHTEN_MAX_RATIO=1.0
RUNNER_REVERSE_BURST_EXIT_ENABLED=true
RUNNER_REVERSE_BURST_ARM_DELAY_SECONDS=60
RUNNER_REVERSE_BURST_CONFIRM_SECONDS=5
RUNNER_REVERSE_SELL_RATIO=0.58
RUNNER_REVERSE_BUY_RATIO=0.58
RUNNER_REVERSE_STRONG_RATIO=0.62
RUNNER_REVERSE_MIN_PRICE_DAMAGE_PCT=0.0015
RUNNER_REVERSE_RECOVERY_CANCEL_PCT=0.001
RUNNER_MAX_TREND_SECONDS_AFTER_SECOND_TP=18000

# Middle Runner remains available, but Three-Stage Runner has priority when enabled.
MIDDLE_RUNNER_ENABLED=false
MIDDLE_RUNNER_FIRST_CLOSE_RATIO=0.8
MIDDLE_RUNNER_EXTENSION_TRIGGER_RATIO=0.6
MIDDLE_RUNNER_DISABLE_ADD_AFTER_PARTIAL=true
MIDDLE_RUNNER_PROTECTIVE_SL_ENABLED=true


# --- account / position sync ---
POSITION_SYNC_SECONDS=5
ACCOUNT_SYNC_SECONDS=60
ACCOUNT_LOG_MIN_DELTA_USDT=0.01
LATEST_MARKET_PRICE_MAX_AGE_SECONDS=30

# --- watchdog launcher ---
WATCHDOG_RESTART_SECONDS=5
WATCHDOG_MAX_RESTARTS=0
# Optional override if python command is not simply `python`.
# LIVE_PYTHON_BIN=/root/miniconda3/envs/c/bin/python
# LIVE_SCRIPT=scripts/run_boll_cvd_live.py
# LIVE_LOG_FILE=boll_cvd_live.out

# --- daily report / reserved configs ---
DAILY_REPORT_TIME=09:00
WEEKLY_SUMMARY_ENABLED=true
WEEKLY_SUMMARY_WEEKDAY=0
WEEKLY_SUMMARY_TIME=10:00
TARGET_NOTIONAL_USDT=1500000

# --- Trend Upgrade Add-on ---
# When enabled, Three-Stage runner positions can be upgraded to trend management
# and receive an independent risk-sized add-on when trend confirms.
TREND_UPGRADE_ADDON_ENABLED=false
# Ratio of TP1+TP2 realized profit that can be reinvested as add-on risk.
TREND_UPGRADE_PROFIT_REINVEST_RATIO=0.30
# Maximum equity fraction that can be risked on a single Trend Upgrade Add-on.
TREND_UPGRADE_MAX_ADDON_RISK_PCT=0.002
# Multiplier on current total notional to cap add-on notional (1.0 = equal to existing).
TREND_UPGRADE_MAX_TOTAL_NOTIONAL_MULTIPLIER=1.0
# Require TP1 consumed before runner can be upgraded.
TREND_UPGRADE_REQUIRE_TP1_CONSUMED=true
# Require TP2 consumed before runner can be upgraded.
TREND_UPGRADE_REQUIRE_TP2_CONSUMED=true
# Minimum remaining runner ratio to qualify for upgrade (0.05 = 5%).
TREND_UPGRADE_MIN_RUNNER_REMAINING_RATIO=0.05
# Minimum trend confidence from RegimeRouter before add-on is allowed.
TREND_UPGRADE_MIN_TREND_CONFIDENCE=0.80

# --- 仓位亏损风控 ---
# FLAT-to-FLAT cumulative drawdown guard. Percent values are decimals: 0.10 = 10%, 0.5 = 50%.
ROLLING_LOSS_GUARD_ENABLED=true
ROLLING_LOSS_WARN_PCT=0.5
ROLLING_LOSS_SOFT_HALT_PCT=0.10
ROLLING_LOSS_SOFT_HALT_HOURS=12
ROLLING_LOSS_HARD_HALT_PCT=0.20
ROLLING_LOSS_HARD_HALT_HOURS=24
