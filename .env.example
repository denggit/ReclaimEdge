# ===========================================================================
# ReclaimEdge .env example
# ===========================================================================
#
# A08+ config split:
#   - Strategy / per-symbol trading parameters live in config/symbols/*.toml
#     by default.
#   - .env still owns secrets, live gate, Trader env, orchestration, runtime
#     paths, email/reporting.
#   - Set RECLAIM_USE_SYMBOL_TOML=false only to temporarily use the legacy
#     .env strategy-parameter path.
# ===========================================================================

# ---------------------------------------------------------------------------
# 1. Live gate
# ---------------------------------------------------------------------------

LIVE_TRADING=false
RECLAIM_RUN_MODE=live
RECLAIM_USE_SYMBOL_TOML=true
RECLAIM_SYMBOLS=ETH-USDT-SWAP
RECLAIM_SYMBOL_CONFIG_DIR=config/symbols
RECLAIM_RUNTIME_DIR=runtime

# ---------------------------------------------------------------------------
# 2. OKX credentials
# ---------------------------------------------------------------------------

OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHASE=

# Important: current code uses OKX_PASSPHASE, not OKX_PASSPHRASE.

# ---------------------------------------------------------------------------
# 3. Trader / env values (must match TOML when RECLAIM_USE_SYMBOL_TOML=true)
# ---------------------------------------------------------------------------
# When RECLAIM_USE_SYMBOL_TOML=true, these Trader values are checked against
# config/symbols/ETH-USDT-SWAP.toml.  Mismatch causes startup failure.

OKX_INST_ID=ETH-USDT-SWAP
OKX_TD_MODE=isolated
OKX_POS_SIDE_MODE=net
LEVERAGE=15
OKX_BASE_URL=https://www.okx.com
OKX_PRIVATE_REST_TIMEOUT_SECONDS=10
MAX_LIVE_EQUITY_USDT=30

# ---------------------------------------------------------------------------
# 4. Email / reporting
# ---------------------------------------------------------------------------

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
DAILY_REPORT_TIME=09:00
WEEKLY_SUMMARY_ENABLED=true
WEEKLY_SUMMARY_TIME=10:00
WEEKLY_SUMMARY_WEEKDAY=0
WEEKLY_COMPACT_AFTER_SUCCESS=false

# ---------------------------------------------------------------------------
# 5. Runtime worker / queue / sync (remain in .env until B phase)
# ---------------------------------------------------------------------------

STRATEGY_TICK_QUEUE_MAXSIZE=20000
EXECUTION_QUEUE_MAXSIZE=1000
POSITION_SYNC_SECONDS=5
ACCOUNT_SYNC_SECONDS=60
ACCOUNT_LOG_MIN_DELTA_USDT=0.01
MARKET_TICK_HEARTBEAT_SECONDS=60
ACCOUNT_SNAPSHOT_STALE_WARN_SECONDS=30
STRATEGY_TICK_LAG_WARN_SECONDS=2
EXECUTION_QUEUE_BACKLOG_LOG_SECONDS=30

# ---------------------------------------------------------------------------
# 6. Legacy strategy parameters
# ---------------------------------------------------------------------------
# IMPORTANT:
#   These legacy strategy params intentionally duplicate some TOML settings.
#   They are here only for RECLAIM_USE_SYMBOL_TOML=false fallback.
#   With the default RECLAIM_USE_SYMBOL_TOML=true, edit
#   config/symbols/ETH-USDT-SWAP.toml instead.
#   Some TOML fields are pending wiring; see docs/configuration.md before
#   relying on them.
#
# These are ignored by default after A08 because RECLAIM_USE_SYMBOL_TOML=true.
# They only take effect when RECLAIM_USE_SYMBOL_TOML=false.
# Prefer editing config/symbols/ETH-USDT-SWAP.toml instead.

# -- BOLL / monitor params (legacy) ------------------------------------------
# BOLL_MIN_OUTSIDE_PCT is wired in TOML as [market].min_outside_pct.
OKX_BAR=15m
BOLL_WINDOW=20
BOLL_STD_MULTIPLIER=2.0
BOLL_DISTANCE_THRESHOLD_PCT=0.005
ALERT_FREEZE_SECONDS=3600
BOLL_USE_LIVE_CANDLE=true
BOLL_RECALC_SECONDS=1
CANDLE_POLL_SECONDS=30
CANDLE_LIMIT=100
TP_BOLL_ENABLED=true
TP_BOLL_WINDOW=15

# -- CVD / burst params (legacy) --------------------------------------------
CVD_FAST_WINDOW_SECONDS=5
PRICE_STALL_SECONDS=2
PRICE_STALL_TOLERANCE_PCT=0.0005
BURST_WINDOW_SECONDS=3
BURST_BASELINE_SECONDS=60
BURST_MIN_MOVE_RATIO=2.5
BURST_MIN_VOLUME_RATIO=2.0
BURST_MIN_ABS_RANGE_PCT=0.0015

# -- Position sizing (legacy) ------------------------------------------------
# FIRST_ADD_BLOCK_SECONDS and ADD_MIN_INTERVAL_SECONDS are wired in TOML
# under [entry].
DRY_RUN_EQUITY_USDT=1000
LAYER_MARGIN_PCT=0.03
MAX_LAYERS=8
LAYER_MULTIPLIER_STEP=0.15

# -- Strategy / TP (legacy) --------------------------------------------------
ADD_GAP_MODE=linear
ADD_GAP_BASE_PCT=0.003
ADD_GAP_STEP_PCT=0.001
TP_MIN_NET_PROFIT_PCT=0.002
THREE_STAGE_RUNNER_ENABLED=true
THREE_STAGE_TP1_RATIO=0.70
THREE_STAGE_TP2_RATIO=0.20
THREE_STAGE_RUNNER_RATIO=0.10
THREE_STAGE_TP2_USE_STRUCTURE_BOLL=true
MIDDLE_RUNNER_ENABLED=false
# SPLIT_TP_ENABLED is wired in TOML under [tp].

# -- Sidecar (legacy) --------------------------------------------------------
SIDECAR_ENABLED=false
SIDECAR_MARGIN_PCT=0.01
SIDECAR_TP_PCT=0.004
SIDECAR_MAX_LEGS=10
SIDECAR_SKIP_FIRST_LAYER=true
SIDECAR_ORDER_STATUS_CHECK_SECONDS=5
SIDECAR_TP_PLACE_RETRY_COUNT=3
SIDECAR_TP_PLACE_RETRY_INTERVAL_SECONDS=0.8
SIDECAR_TP_PLACE_RETRY_BACKOFF_MULTIPLIER=1.5
SIDECAR_TP_RATE_LIMIT_FAIL_ACTION=HALT_ONLY

# -- Portfolio allocator shadow mode (G05) -------------------------------------
# Disabled by default; does not block orders.  When enabled, every entry
# command schedules a fire-and-forget background dry-run check that records
# the allocator decision as a journal event WITHOUT affecting the real order
# path.  Empty PORTFOLIO_LEDGER_PATH / LOCK_PATH fall back to the default
# runtime/portfolio paths.
PORTFOLIO_ALLOCATOR_SHADOW_ENABLED=false
PORTFOLIO_ALLOCATOR_GLOBAL_MAIN_CAP_PCT=0.70
PORTFOLIO_LEDGER_PATH=
PORTFOLIO_LEDGER_LOCK_PATH=
PORTFOLIO_ALLOCATOR_SHADOW_LOCK_TIMEOUT_SECONDS=0.25

# -- Portfolio allocator enforce mode (G06a) ------------------------------------
# Disabled by default; does not block orders.  When enabled, OPEN/ADD/SIDECAR
# new-risk intents must pass the allocator before order placement.  Exit/reduce
# actions are never blocked.  Rejected intents skip the real order (fail closed).
# Empty PORTFOLIO_LEDGER_PATH / LOCK_PATH fall back to the default
# runtime/portfolio paths (shared with G05 shadow mode).
PORTFOLIO_ALLOCATOR_ENFORCE_ENABLED=false
PORTFOLIO_ALLOCATOR_ENFORCE_LOCK_TIMEOUT_SECONDS=1.0

# -- Risk (legacy) -----------------------------------------------------------
ROLLING_LOSS_GUARD_ENABLED=true
ROLLING_LOSS_WARN_PCT=0.50
ROLLING_LOSS_SOFT_HALT_PCT=0.10
ORDER_FAILURE_MARKET_EXIT_DELAY_SECONDS=1800
PRIVATE_WRITE_MIN_INTERVAL_SECONDS=0.6
MAX_ORDER_RETRIES=3
