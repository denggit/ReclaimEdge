# --- OKX config ---
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHASE=
OKX_INST_ID=ETH-USDT-SWAP
OKX_BAR=15m
OKX_TD_MODE=isolated
OKX_POS_SIDE_MODE=net
OKX_BASE_URL=https://www.okx.com

# --- live trading safety ---
LIVE_TRADING=false
MAX_LIVE_EQUITY_USDT=30

# --- email, failure only in live runner ---
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# --- BOLL params ---
BOLL_WINDOW=20
BOLL_STD_MULTIPLIER=2.0
BOLL_DISTANCE_THRESHOLD_PCT=0.005
BOLL_USE_LIVE_CANDLE=true
BOLL_RECALC_SECONDS=1

# --- candle polling / REST calibration ---
CANDLE_POLL_SECONDS=30
CANDLE_LIMIT=100

# --- original BOLL alert deduplication ---
# This is for the legacy BOLL breakout alert, not the live strategy order cooldown.
ALERT_FREEZE_SECONDS=3600

# --- fast CVD reclaim strategy ---
CVD_FAST_WINDOW_SECONDS=5
CVD_MIN_BUY_RATIO=0.55
CVD_MIN_SELL_RATIO=0.55
PRICE_STALL_SECONDS=2
PRICE_STALL_TOLERANCE_PCT=0.0005

# --- burst filter: block slow grinding moves along BOLL bands ---
# The burst filter is relative: short-window range/volume must expand vs baseline.
BURST_WINDOW_SECONDS=3
BURST_BASELINE_SECONDS=60
BURST_MIN_MOVE_RATIO=2.5
BURST_MIN_VOLUME_RATIO=2.0

# --- live/dry-run position sizing ---
# Live runner uses real OKX account equity; DRY_RUN_EQUITY_USDT is mainly for dry-run scripts.
DRY_RUN_EQUITY_USDT=1000
LAYER_MARGIN_PCT=0.03
LEVERAGE=50
ADD_LAYER_GAP_PCT=0.003
MAX_LAYERS=3
ORDER_COOLDOWN_SECONDS=10
# Deprecated: interval bypass now uses target layer gap * 2.
ADD_MIN_INTERVAL_BYPASS_GAP_PCT=0.005
TP_UPDATE_INTERVAL_SECONDS=900
MAX_ENTRY_DISTANCE_FROM_EXTREME_PCT=0.002
MAX_ARMED_SECONDS=900
BREAKEVEN_FEE_BUFFER_PCT=0.001

# --- take-profit management ---
# Three-Stage Trend Runner only applies when first TP mode is MIDDLE.
THREE_STAGE_RUNNER_ENABLED=true
THREE_STAGE_TP1_RATIO=0.60
THREE_STAGE_TP2_RATIO=0.20
THREE_STAGE_RUNNER_RATIO=0.20
# After TP1 middle is filled, protect the remaining 40% before TP2.
THREE_STAGE_POST_TP1_PROTECTIVE_SL_ENABLED=true
# Move post-TP1 protective SL to middle after price travels this ratio from middle to outer band.
THREE_STAGE_POST_TP1_SL_EXTENSION_TRIGGER_RATIO=0.60
RUNNER_DYNAMIC_ENABLED=true
# Reserved for future timer-based runner updates.
# Current Trend Runner TP/SL updates are driven by completed 15m BOLL candle timestamps.
RUNNER_DYNAMIC_UPDATE_SECONDS=900
RUNNER_TP_INITIAL_OUTER_EXTRA_PCT=0.010
RUNNER_TP_STEP_PCT=0.001
RUNNER_TP_MIN_OUTER_EXTRA_PCT=0.004
RUNNER_SL_INITIAL_OUTER_DISTANCE_RATIO=1.00
RUNNER_SL_STEP_RATIO=0.10
RUNNER_SL_MIN_OUTER_DISTANCE_RATIO=0.50
RUNNER_REVERSE_BURST_EXIT_ENABLED=true
RUNNER_REVERSE_BURST_ARM_DELAY_SECONDS=60
RUNNER_REVERSE_BURST_CONFIRM_SECONDS=5
RUNNER_REVERSE_SELL_RATIO=0.58
RUNNER_REVERSE_BUY_RATIO=0.58
RUNNER_REVERSE_STRONG_RATIO=0.62
RUNNER_REVERSE_MIN_PRICE_DAMAGE_PCT=0.0015
RUNNER_REVERSE_RECOVERY_CANCEL_PCT=0.001
RUNNER_MAX_TREND_SECONDS_AFTER_SECOND_TP=18000

# Middle Runner remains available, but Three-Stage Runner has priority when enabled.
MIDDLE_RUNNER_ENABLED=false
MIDDLE_RUNNER_FIRST_CLOSE_RATIO=0.8
MIDDLE_RUNNER_EXTENSION_TRIGGER_RATIO=0.6
MIDDLE_RUNNER_DISABLE_ADD_AFTER_PARTIAL=true
MIDDLE_RUNNER_PROTECTIVE_SL_ENABLED=true

# Near-TP Reduce must stay disabled when Middle Runner or Three-Stage Runner is enabled.
NEAR_TP_ENABLED=false
NEAR_TP_REDUCE_ENABLED=false
NEAR_TP_SHADOW_ENABLED=false

# Original Split TP remains available, but keep it disabled for Three-Stage Runner live config.
SPLIT_TP_ENABLED=false
SPLIT_TP_MIN_LAYERS=4
SPLIT_TP_PATH_RATIO=0.8
SPLIT_TP_PARTIAL_RATIO=0.5
SPLIT_TP_MIN_PROFIT_PCT=0.004

# --- account / position sync ---
POSITION_SYNC_SECONDS=5
ACCOUNT_SYNC_SECONDS=60
ACCOUNT_LOG_MIN_DELTA_USDT=0.01
LATEST_MARKET_PRICE_MAX_AGE_SECONDS=30

# --- watchdog launcher ---
WATCHDOG_RESTART_SECONDS=5
WATCHDOG_MAX_RESTARTS=0
# Optional override if python command is not simply `python`.
# LIVE_PYTHON_BIN=/root/miniconda3/envs/c/bin/python
# LIVE_SCRIPT=scripts/run_boll_cvd_live.py
# LIVE_LOG_FILE=boll_cvd_live.out

# --- daily report / reserved configs ---
DAILY_REPORT_TIME=09:00
WEEKLY_SUMMARY_ENABLED=true
WEEKLY_SUMMARY_WEEKDAY=0
WEEKLY_SUMMARY_TIME=10:00
TARGET_NOTIONAL_USDT=1500000
